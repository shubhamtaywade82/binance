# -----------------------------------------------------------------------------
# Minimal surface — defaults are baked into the app (MTF stack, TP/SL %, logs).
# Pick market only:
TRADING_ASSET=sol
# TRADING_ASSET=eth
# TRADING_ASSET=btc
# TRADING_ASSET=custom   → then set BINANCE_SYMBOL + COINDCX_PAIR yourself

# CoinDCX — required only for live execution
COINDCX_API_KEY=
COINDCX_API_SECRET=

# Execution: default full bot + **paper** simulated fills (no CoinDCX/Binance *order* APIs).
# `EXECUTION_MODE=paper` (default) + `READ_ONLY=true` (default) = nothing sent to exchanges.
# Signals-only (no simulated positions): PLACE_ORDER=false
PLACE_ORDER=true
READ_ONLY=true
EXECUTION_MODE=paper

# Optional overrides (uncomment only when you need to diverge from presets)
# API_BASE_URL=https://api.coindcx.com
# BINANCE_FUTURES_TESTNET=false
# APP_LOG_PATH=./logs/app.ndjson

# Optional Binance checks / endpoint overrides
# BINANCE_REST_BASE=https://fapi.binance.com
# BINANCE_WS_BASE=wss://fstream.binance.com
# BINANCE_TIMEFRAMES=5m,15m,1h,4h,1d
# TP_PRICE_PCT=0.015
# SL_PRICE_PCT=0.01
