# =============================================================================
# Environment template — Binance public data + CoinDCX / Binance execution
# =============================================================================
# Quick start: cp .env.example .env
#
# This file lists every variable the app reads, each on an active KEY=value line
# (nothing is “commented out” as a setting). Values here default to:
#   · Binance USD-M FUTURES TESTNET (public market data + testnet URLs)
#   · Paper execution (no live orders until you change EXECUTION_MODE / keys)
#
# Section comments below are documentation only; they are not alternate values.
# =============================================================================

# ─── Market & symbol preset (change assets here) ───────────────────────────
# TRADING_ASSET: sol | eth | btc | custom
#   Presets (overwrite BINANCE_SYMBOL + COINDCX_PAIR unless TRADING_ASSET=custom):
#     sol   → BINANCE_SYMBOL=SOLUSDT    COINDCX_PAIR=B-SOL_USDT
#     eth   → BINANCE_SYMBOL=ETHUSDT    COINDCX_PAIR=B-ETH_USDT
#     btc   → BINANCE_SYMBOL=BTCUSDT    COINDCX_PAIR=B-BTC_USDT
#   custom → set BINANCE_SYMBOL and COINDCX_PAIR explicitly below (no preset merge).
# Preset table source: src/config/asset-presets.ts
TRADING_ASSET=sol

BINANCE_PRODUCT=usdm
# Optional overrides (leave empty to use code defaults from BINANCE_FUTURES_TESTNET / product):
#   With BINANCE_FUTURES_TESTNET=true, REST defaults to https://testnet.binancefuture.com
#   and WS to wss://fstream.binancefuture.com (see src/config.ts binanceRestBase / binanceWsBase).
BINANCE_REST_BASE=
BINANCE_WS_BASE=
# Primary Binance USD-M symbol (execution + strategy + default chart). Overwritten by
# TRADING_ASSET=sol|eth|btc; for custom assets you set this and COINDCX_PAIR yourself.
BINANCE_SYMBOL=SOLUSDT
# Extra USD-M symbols on the same multiplex stream (comma-separated, no spaces).
# Dashboard watchlist tabs; data only — execution stays on BINANCE_SYMBOL unless you change it.
# Example: BINANCE_WATCHLIST=ETHUSDT,BTCUSDT
BINANCE_WATCHLIST=SOLUSDT,ETHUSDT,BTCUSDT
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# ─── CoinDCX (legacy live execution path) ───────────────────────────────────
# Required when EXECUTION_MODE=live and BINANCE_EXECUTION_ADAPTER=false.
# COINDCX_PAIR: futures pair id (e.g. B-SOL_USDT). With TRADING_ASSET=sol|eth|btc this is
# preset from src/config/asset-presets.ts; with TRADING_ASSET=custom set it to match your venue pair.
COINDCX_API_KEY=
COINDCX_API_SECRET=
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com
COINDCX_PAIR=B-SOL_USDT

# ─── Execution safety ───────────────────────────────────────────────────────
# EXECUTION_MODE: paper — simulated fills locally (default safe). live — real orders.
# READ_ONLY: when true, broker adapters avoid mutating calls where applicable.
# PLACE_ORDER: false = signals only (no paper positions). true = paper/live fills per mode.
# EXECUTION_ENABLED: legacy alias read only if PLACE_ORDER is unset in env.
READ_ONLY=true
PLACE_ORDER=true
EXECUTION_ENABLED=true
EXECUTION_MODE=paper

LOG_HEARTBEAT_SEC=60
LTP_CONNECT_WARN_SEC=15
# USD-M: poll GET /fapi/v1/premiumIndex when mark WS is silent; 0 disables.
USDM_MARK_REST_POLL_SEC=5

# ─── Risk & sizing ──────────────────────────────────────────────────────────
LEVERAGE=10
# CAPITAL_PER_TRADE_USDT > 0 prefers USDT margin sizing; 0 uses INR path below.
CAPITAL_PER_TRADE_USDT=0
CAPITAL_PER_TRADE=20000
CAPITAL_PER_TRADE_INR=20000
INR_PER_USDT=85
TARGET_PNL_PCT=0.10
STOP_LOSS_PCT=0.05
TP_PRICE_PCT=0.015
SL_PRICE_PCT=0.01
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT

# ─── Strategy (SMC / MTF) ───────────────────────────────────────────────────
USE_SMC=true
USE_SMC_CONFLUENCE=true
SMC_CONFLUENCE_MODE=standard
SMC_CONFLUENCE_MIN_STANDARD=3
SMC_CONFLUENCE_MIN_SNIPER=4
SMC_CONFLUENCE_TARGET_PCT=0.015
# USE_SOL_MTF_STRATEGY: multi-timeframe stack; requires BINANCE_TIMEFRAMES to include 5m,15m,1h,4h,1d (1m optional for chart).
USE_SOL_MTF_STRATEGY=true

TRADES_CSV_PATH=./logs/trades.csv
TRADE_LOG_PATH=./logs/trades.csv
APP_LOG_PATH=./logs/app.ndjson

# ─── Paper trading ──────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_MAINT_MARGIN=0.005
PAPER_BASE_SLIPPAGE_BPS=2
PAPER_LATENCY_MS=150
PAPER_LEDGER_DIR=./paper
PAPER_FUNDING_POLL_SEC=300
PAPER_EQUITY_SNAPSHOT_SEC=5

# ─── Binance market data (multiplex / dashboard) ─────────────────────────────
# BINANCE_TIMEFRAMES: comma-separated; first interval is execution LTF close when multiplex runs bot.
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d
BINANCE_HISTORY_BARS=500
BINANCE_DEPTH_LEVELS=20
BINANCE_DEPTH_SPEED=100ms
BINANCE_USE_AGGTRADE=true
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true
# BINANCE_USE_FORCE_ORDER: stream @forceOrder (USD-M) for SMC liquidity sweep hints.
BINANCE_USE_FORCE_ORDER=false
BINANCE_WS_RECONNECT_HOURS=23

# ─── Binance USD-M testnet vs mainnet ───────────────────────────────────────
# BINANCE_FUTURES_TESTNET=true → REST https://testnet.binancefuture.com, WS wss://fstream.binancefuture.com
# Set false for mainnet public endpoints (still paper execution unless you go live below).
# Register / keys: https://testnet.binancefuture.com
BINANCE_FUTURES_TESTNET=true

# ─── Binance FAPI HMAC (live orders when BINANCE_EXECUTION_ADAPTER=true) ─────
# Mainnet: create API key on binance.com → enable Futures → IP-restrict before live.
# Testnet: use testnet keypair when BINANCE_FUTURES_TESTNET=true.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_EXECUTION_ADAPTER=false
# Private user-data WS (ORDER_TRADE_UPDATE, ACCOUNT_UPDATE). Auto-on when adapter+live.
BINANCE_PRIVATE_WS_ENABLED=false

# ─── Binance WebSocket trading API (Ed25519, optional advanced) ─────────────
# ws-fapi session / order.place — separate from public fstream; not required for REST adapter.
# https://developers.binance.com/docs/derivatives/usds-margined-futures/websocket-api-general-info
BINANCE_FAPI_WS_ENABLED=false
BINANCE_FAPI_API_KEY=
BINANCE_FAPI_ED25519_PRIVATE_KEY_PATH=
BINANCE_FAPI_WS_URL=
BINANCE_FAPI_WS_REQUEST_TIMEOUT_MS=30000
BINANCE_FAPI_WS_HIDE_RATELIMITS=false

# ─── Dashboard WebSocket (same process as `npm run dev` / `npm start`) ───────
# When true, the bot exposes the browser UI bridge on ws://DASHBOARD_BIND:DASHBOARD_PORT
# using the same multiplex-backed store/orderbook/trade tape as the strategy (no duplicate Binance WS).
# Optional UI: `npm run ui:dev` (Vite). `npm run dashboard` is an alias with this flag set.
DASHBOARD_ENABLED=false
DASHBOARD_PORT=4001
DASHBOARD_BIND=127.0.0.1
DASHBOARD_STORE_MAX_BARS=100000
# Vite dashboard UI only: fallback LTP decimals (1…8) when the bot has not yet sent `ltpDecimalPlaces`.
# When the bot sends them, each value is (Binance tickSize fractional digits + 1) for sub-tick display.
# Restart `npm run ui:dev` / rebuild after change.
VITE_LTP_DECIMAL_PLACES=4

# ─── Dashboard AI brief (ollama JS) ─────────────────────────────────────────
# AI_MARKET_BRIEF_ENABLED: optional narrative when dashboard is enabled (see DASHBOARD_ENABLED).
# OLLAMA_TARGET: local | cloud (URLs fixed in code: 127.0.0.1:11434 vs https://ollama.com).
# OLLAMA_API_KEY: required when OLLAMA_TARGET=cloud.
AI_MARKET_BRIEF_ENABLED=true
OLLAMA_TARGET=local
OLLAMA_MODEL=llama3.2:3b
OLLAMA_API_KEY=
AI_BRIEF_INTERVAL_SEC=120
AI_REQUEST_TIMEOUT_MS=25000
# AI_SUPERTREND_TUNING_ENABLED: when true, periodically asks Ollama for SuperTrend atrPeriod (5–30) and multiplier (1.5–5); chart math stays local.
# AI_SUPERTREND_TUNING_INTERVAL_SEC: minimum seconds between tuning calls per symbol (60–3600).
AI_SUPERTREND_TUNING_ENABLED=false
AI_SUPERTREND_TUNING_INTERVAL_SEC=300

# ─── Process shutdown (orchestrator / lifecycle) ────────────────────────────
SHUTDOWN_TIMEOUT_MS=5000
SHUTDOWN_FORCE_EXIT_MS=10000
