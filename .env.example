# =============================================================================
# DEFAULT PAPER PROFILE - all optional features enabled
# Complete profile generated from src/config.ts.
# All AppConfig keys are active KEY=value lines.
# Optional feature flags are enabled; PLACE_ORDER=false blocks adapter submission.
# .env.secrets is loaded first and can override the placeholder secret values below.
# =============================================================================

# --- Market and symbols ---
TRADING_ASSET=sol
BINANCE_PRODUCT=usdm
BINANCE_REST_BASE=
BINANCE_WS_BASE=
BINANCE_SYMBOL=SOLUSDT
BINANCE_WATCHLIST=SOLUSDT,BTCUSDT,ETHUSDT,SUIUSDT,AVAXUSDT,LINKUSDT,XRPUSDT
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# --- CoinDCX and public API endpoints ---
COINDCX_API_KEY=replace_me_coindcx_api_key
COINDCX_API_SECRET=replace_me_coindcx_api_secret
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com
COINDCX_PAIR=B-SOL_USDT

# --- Execution safety ---
READ_ONLY=true
PLACE_ORDER=false
SHADOW_MODE=false

# --- Runtime logging ---
LOG_HEARTBEAT_SEC=60
LTP_CONNECT_WARN_SEC=15
USDM_MARK_REST_POLL_SEC=5

# --- Risk and sizing ---
LEVERAGE=10
MAX_NOTIONAL_USDT=50
CAPITAL_PER_TRADE_USDT=1000
CAPITAL_PER_TRADE=20000
CAPITAL_PER_TRADE_INR=20000
INR_PER_USDT=85
INR_RATE_SOURCE=coindcx
INR_RATE_REFRESH_SEC=300
TARGET_PNL_PCT=0.10
STOP_LOSS_PCT=0.05
TP_PRICE_PCT=0.015
SL_PRICE_PCT=0.01
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT

# --- SMC strategy ---
USE_SMC=true
USE_SMC_CONFLUENCE=true
SMC_CONFLUENCE_MODE=sniper
SMC_CONFLUENCE_MIN_STANDARD=3
SMC_CONFLUENCE_MIN_SNIPER=4
SMC_CONFLUENCE_TARGET_PCT=0.015
USE_SOL_MTF_STRATEGY=true

# --- Logs and paper ledger ---
TRADES_CSV_PATH=./logs/trades.csv
TRADE_LOG_PATH=./logs/trades.csv
APP_LOG_PATH=./logs/app.ndjson
LOG_JSON_CONSOLE=true

# --- Execution mode and paper engine ---
EXECUTION_MODE=paper
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_MAINT_MARGIN=0.005
PAPER_BASE_SLIPPAGE_BPS=2
PAPER_LATENCY_MS=150
PAPER_LEDGER_DIR=./paper
PAPER_FUNDING_POLL_SEC=300
PAPER_EQUITY_SNAPSHOT_SEC=5
PAPER_PARTIAL_FILLS=true
PAPER_MAX_SLIPPAGE_BPS=20

# --- Binance market data ---
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d
BINANCE_HISTORY_BARS=500
BINANCE_DEPTH_LEVELS=20
BINANCE_DEPTH_SPEED=100ms
BINANCE_USE_AGGTRADE=true
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true
BINANCE_USE_FORCE_ORDER=true
BINANCE_USE_GLOBAL_FORCE_ORDER=true
BINANCE_WS_RECONNECT_HOURS=23

# --- Binance REST retry policy ---
BINANCE_REST_RETRY_MAX_ATTEMPTS=4
BINANCE_REST_RETRY_BASE_MS=400
BINANCE_REST_RETRY_MAX_MS=20000

# --- Binance credentials and live adapter ---
BINANCE_FUTURES_TESTNET=false
BINANCE_API_KEY=replace_me_binance_api_key
BINANCE_API_SECRET=replace_me_binance_api_secret
BINANCE_TESTNET_API_KEY=replace_me_binance_testnet_api_key
BINANCE_TESTNET_API_SECRET=replace_me_binance_testnet_api_secret
CONFIRMED_LIVE_TRADING=true
BINANCE_EXECUTION_ADAPTER=true
BINANCE_PRIVATE_WS_ENABLED=true

# --- Binance FAPI WebSocket API ---
BINANCE_FAPI_WS_ENABLED=true
BINANCE_FAPI_API_KEY=replace_me_binance_fapi_api_key
BINANCE_FAPI_ED25519_PRIVATE_KEY_PATH=./secrets/binance-ed25519.pem
BINANCE_FAPI_WS_URL=
BINANCE_FAPI_WS_REQUEST_TIMEOUT_MS=30000
BINANCE_FAPI_WS_HIDE_RATELIMITS=true

# --- Dashboard and AI brief ---
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4001
DASHBOARD_BIND=127.0.0.1
DASHBOARD_STORE_MAX_BARS=100000
AI_MARKET_BRIEF_ENABLED=true
AI_PROVIDER=ollama
AI_OPENAI_URL=http://127.0.0.1:8080/v1
AI_OPENAI_MODEL=local-model
OLLAMA_TARGET=local
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_API_KEY=replace_me_ollama_api_key
AI_BRIEF_INTERVAL_SEC=120
AI_BRIEF_FORCED_COOLDOWN_SEC=45
AI_BRIEF_THINK_ENABLED=true
AI_BRIEF_STREAM_ENABLED=true
AI_CONTEXT_SIZE=8192
AI_REQUEST_TIMEOUT_MS=120000
AI_MCP_ENABLED=true
AI_MCP_URL=http://localhost:4003
AI_MCP_MAX_TOOL_ITER=4
AI_SUPERTREND_TUNING_ENABLED=true
AI_SUPERTREND_TUNING_INTERVAL_SEC=300

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=replace_me_telegram_bot_token
TELEGRAM_CHAT_ID=replace_me_telegram_chat_id
TELEGRAM_ALERT_LEVELS=critical,trade,signal,trail,wallet,ai,system
TELEGRAM_RATE_PER_MIN=20
TELEGRAM_TRAIL_THROTTLE_SEC=300
TELEGRAM_WALLET_DELTA_PCT=0.02
TELEGRAM_WALLET_INTERVAL_MIN=30
TELEGRAM_DIGEST_INTERVAL_MIN=360

# --- Live risk guards ---
BINANCE_DEADMAN_COUNTDOWN_MS=120000
DAILY_DRAWDOWN_KILL_PCT=0.05
ORDER_RATE_LIMIT_PAUSE_THRESHOLD=0.92
MAX_ENTRY_SPREAD_BPS=10
MAX_OPEN_POSITIONS=3
MAX_TOTAL_EXPOSURE_USDT=100000
MAX_OPEN_SYMBOLS=5

# --- Event-bus execution path ---
EVENT_BUS_EXECUTION_ENABLED=true
STALE_FEED_THRESHOLD_MS=30000
STALE_FEED_CHECK_INTERVAL_MS=5000
MIN_SIGNAL_CONFIDENCE=0.6
EVENT_BUS_ORDER_COOLDOWN_MS=300000

# --- Seykota strategy ---
SEYKOTA_ENABLED=true
SEYKOTA_HTF=1h
SEYKOTA_FAST_EMA=20
SEYKOTA_SLOW_EMA=50
SEYKOTA_ADX_PERIOD=14
SEYKOTA_ADX_THRESHOLD=20
SEYKOTA_ATR_PERIOD=14
SEYKOTA_ATR_MULT=3
SEYKOTA_MIN_ATR_PCT=0.003
SEYKOTA_RISK_PCT=0.005
SEYKOTA_EQUITY_USDT=10000
SEYKOTA_MIN_BARS=80
SEYKOTA_KLINE_ONLY=true
SEYKOTA_PARTIAL_TP_R=1
SEYKOTA_PARTIAL_TP_PCT=0.5
SEYKOTA_SMC_EXIT_ENABLED=true
SEYKOTA_PYRAMID_MAX_ADDS=2
SEYKOTA_PYRAMID_R_DISTANCE=1.0

# --- Redis paper state ---
PAPER_STATE_REDIS=true
REDIS_NAMESPACE=binance
PAPER_EQUITY_JSONL_EVERY_N=12

# --- Signal allocator and correlation guard ---
SIGNAL_ALLOCATOR_ENABLED=true
SIGNAL_ALLOCATOR_MODE=score
SIGNAL_ALLOCATOR_FLUSH_MS=1500
CORRELATION_PAIRS_JSON=[{"symbolA":"BTCUSDT","symbolB":"ETHUSDT","correlation":0.85},{"symbolA":"SOLUSDT","symbolB":"AVAXUSDT","correlation":0.75}]
CORRELATION_THRESHOLD=0.7

# --- Exit managers ---
SEYKOTA_TRAIL_INTRABAR=true
PARTIAL_TP_ENABLED=true
PARTIAL_TP_R=1
PARTIAL_TP_FRACTION=0.5
TIME_STOP_ENABLED=true
TIME_STOP_BARS=24
STRUCTURE_EXIT_ENABLED=true
STRUCTURE_SWING_LOOKBACK=5
FUNDING_EXIT_ENABLED=true
FUNDING_EXIT_THRESHOLD_BPS=50

# --- Adaptive strategy ---
ADAPTIVE_STRATEGY_ENABLED=true
ADAPTIVE_EQUITY_USDT=10000
ADAPTIVE_COOLDOWN_MS=300000
ADAPTIVE_MODE_OVERRIDES_JSON={}

# --- Live fill/reconciliation behavior ---
LIVE_USE_WS_FOR_FILLS=true

# --- Multi-asset controls ---
BINANCE_CORRELATION_SYMBOL_GROUPS=BTCUSDT,ETHUSDT|SOLUSDT,AVAXUSDT
ENABLE_MULTI_ASSET=true
ASSET_TIER_OVERRIDES_JSON={"SOLUSDT":{"leverage":5,"marginUsdt":1000},"ETHUSDT":{"leverage":5,"marginUsdt":1000}}

# --- Sizing filters and live order style ---
VOL_ADJUSTED_SIZING=true
VOL_BASELINE=50
TRADING_HOURS_UTC=00:00-23:59
ENTRY_ORDER_TYPE=LIMIT_GTX
TRAILING_STOP_CALLBACK_RATE=1

# --- ML inference pipeline ---
ML_ENABLED=true
ML_INFERENCE_URL=http://localhost:8000/infer
ML_MIN_PROBABILITY=0.65
ML_MIN_EDGE_BPS=8
ML_SHADOW_MODE=true
ML_INFERENCE_TIMEOUT_MS=2000
ML_FEATURE_DIR=./data/features
ML_PREDICTION_DIR=./data/predictions

# --- Observability and persistence ---
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true
POSTGRES_URL=postgres://postgres:postgres@localhost:5434/bot
EVENT_WAL_PATH=./data/event-wal.ndjson
EVENT_WAL_COMPACT_AFTER=500

# --- Shutdown ---
SHUTDOWN_TIMEOUT_MS=5000
SHUTDOWN_FORCE_EXIT_MS=10000

# --- Redis and runtime control plane ---
REDIS_URL=redis://localhost:6379
CONTROL_PORT=4002
CONTROL_AUTH_TOKEN=change_me_control_auth_token_32_chars

# --- Self-learning runtime ---
SELF_LEARNING_ENABLED=true
SELF_LEARNING_PAPER_ONLY=false
SELF_LEARNING_INTERVAL_MS=3600000
SELF_LEARNING_OLLAMA_URL=http://127.0.0.1:11434
SELF_LEARNING_OLLAMA_MODEL=qwen3.5:4b

# --- Position manager options ---
DEFAULT_PARTIAL_TARGETS_JSON=[{"r":1,"pct":0.5},{"r":2,"pct":0.25}]
ALLOW_PYRAMIDING=true

# --- Non-AppConfig env used by UI, scripts, gateway, MCP, and dashboards ---
EXECUTION_ENABLED=false
GATEWAY_PORT=4000
NANOPINE_SCRIPTS_PATH=data/nanopine-scripts.json
PG_WRITER_QUEUE_MAX=10000
PG_URL=postgres://postgres:postgres@localhost:5434/bot
SL_PG_MAX=10
FUTURES_LTP_POLL_SEC=1
FUTURES_LTP_WS_PATH=raw
USE_SPOT=false
VITE_LTP_DECIMAL_PLACES=4
VITE_CHART_LTP_SMOOTHING=0.1
VITE_DASHBOARD_WS_URL=ws://localhost:4001
VITE_DASHBOARD_WS_PORT=4001
VITE_NANOPINE_REMOTE=true
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_DASHBOARD_WS_URL=ws://localhost:4001
MCP_HOST=0.0.0.0
MCP_PORT=4003
MCP_TRANSPORT=http
LOG_LEVEL=INFO
