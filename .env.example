# Binance (public USD-M futures by default)
BINANCE_PRODUCT=usdm
BINANCE_REST_BASE=https://fapi.binance.com
BINANCE_WS_BASE=wss://fstream.binance.com
BINANCE_SYMBOL=SOLUSDT
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# CoinDCX (same names as coindcx-bot)
COINDCX_API_KEY=
COINDCX_API_SECRET=
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com

# Mapped CoinDCX futures pair for BINANCE_SYMBOL
COINDCX_PAIR=B-SOL_USDT

# Safety: never place real orders unless both are set
READ_ONLY=true
EXECUTION_ENABLED=false

# Logs: heartbeat every N seconds (mark + biases). 0 = off
LOG_HEARTBEAT_SEC=60

# Risk / sizing (CAPITAL_PER_TRADE treated as USDT-equivalent margin)
LEVERAGE=10
CAPITAL_PER_TRADE=20000
CAPITAL_PER_TRADE_INR=20000
INR_PER_USDT=85
TARGET_PNL_PCT=0.10
STOP_LOSS_PCT=0.05
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT
USE_SMC=true
TRADES_CSV_PATH=./logs/trades.csv
TRADE_LOG_PATH=./logs/trades.csv
