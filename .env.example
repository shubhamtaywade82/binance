# =============================================================================
# Environment template — Binance public data + CoinDCX / Binance execution
# =============================================================================
# Quick start: cp .env.example .env
#
# This file lists every variable the app reads, each on an active KEY=value line
# (nothing is “commented out” as a setting). Values here default to:
#   · Binance USD-M FUTURES TESTNET (public market data + testnet URLs)
#   · Paper execution (no live orders until you change EXECUTION_MODE / keys)
#
# Section comments below are documentation only; they are not alternate values.
# =============================================================================

# ─── Market & symbol preset (change assets here) ───────────────────────────
# TRADING_ASSET: sol | eth | btc | custom
#   Presets (overwrite BINANCE_SYMBOL + COINDCX_PAIR unless TRADING_ASSET=custom):
#     sol   → BINANCE_SYMBOL=SOLUSDT    COINDCX_PAIR=B-SOL_USDT
#     eth   → BINANCE_SYMBOL=ETHUSDT    COINDCX_PAIR=B-ETH_USDT
#     btc   → BINANCE_SYMBOL=BTCUSDT    COINDCX_PAIR=B-BTC_USDT
#   custom → set BINANCE_SYMBOL and COINDCX_PAIR explicitly below (no preset merge).
# Preset table source: src/config/asset-presets.ts
TRADING_ASSET=sol

# BINANCE_PRODUCT: usdm | usdm_demo | spot
#   usdm      → mainnet USD-M Futures (fapi.binance.com / fstream.binance.com)
#   usdm_demo → demo USD-M Futures (demo-fapi.binance.com / demo-fstream.binance.com)
#   spot      → mainnet Spot (api.binance.com / stream.binance.com)
BINANCE_PRODUCT=usdm
# Optional: `usdm_demo` → REST https://demo-fapi.binance.com (Binance demo trading; virtual balances).
# Optional overrides (leave empty to use code defaults from BINANCE_FUTURES_TESTNET / product):
#   With BINANCE_FUTURES_TESTNET=true, REST defaults to https://testnet.binancefuture.com
#   and WS to wss://fstream.binancefuture.com (see src/config.ts binanceRestBase / binanceWsBase).
BINANCE_REST_BASE=
BINANCE_WS_BASE=
# Binance REST retries (408/429/5xx + transport errors) on BinanceRestClient — exponential backoff + full jitter.
# BINANCE_REST_RETRY_MAX_ATTEMPTS=4
# BINANCE_REST_RETRY_BASE_MS=400
# BINANCE_REST_RETRY_MAX_MS=20000
# Primary Binance USD-M symbol (execution + strategy + default chart). Overwritten by
# TRADING_ASSET=sol|eth|btc; for custom assets you set this and COINDCX_PAIR yourself.
BINANCE_SYMBOL=SOLUSDT
# Extra USD-M symbols on the same multiplex stream (comma-separated, no spaces).
# Dashboard watchlist tabs; data only — execution stays on BINANCE_SYMBOL unless you change it.
# Example: BINANCE_WATCHLIST=ETHUSDT,BTCUSDT
BINANCE_WATCHLIST=SOLUSDT,BTCUSDT,ETHUSDT,SUIUSDT,AVAXUSDT,LINKUSDT,XRPUSDT
# Same-direction cluster guard (live Binance REST only): symbols in one cluster (comma) should not
# all be long/short together; separate clusters with `|`. Example: BTCUSDT,ETHUSDT|SOLUSDT,AVAXUSDT
# BINANCE_CORRELATION_SYMBOL_GROUPS=
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# ─── CoinDCX (legacy live execution path) ───────────────────────────────────
# Required when EXECUTION_MODE=live and BINANCE_EXECUTION_ADAPTER=false.
# COINDCX_PAIR: futures pair id (e.g. B-SOL_USDT). With TRADING_ASSET=sol|eth|btc this is
# preset from src/config/asset-presets.ts; with TRADING_ASSET=custom set it to match your venue pair.
COINDCX_API_KEY=
COINDCX_API_SECRET=
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com
COINDCX_PAIR=B-SOL_USDT

# ─── Execution safety ───────────────────────────────────────────────────────
# EXECUTION_MODE: paper — simulated fills locally (default safe). live — real orders.
# READ_ONLY: when true, broker adapters avoid mutating calls where applicable.
# PLACE_ORDER: false = signals only (no paper positions). true = paper/live fills per mode.
# EXECUTION_ENABLED: legacy alias read only if PLACE_ORDER is unset in env.
READ_ONLY=true
PLACE_ORDER=true
EXECUTION_ENABLED=true
EXECUTION_MODE=paper
# SHADOW_MODE=true — log order intent only; never call the execution adapter (Phase 3 rehearsal).
SHADOW_MODE=false

LOG_HEARTBEAT_SEC=60
LTP_CONNECT_WARN_SEC=15
# USD-M: poll GET /fapi/v1/premiumIndex when mark WS is silent; 0 disables.
USDM_MARK_REST_POLL_SEC=5

# ─── Risk & sizing ──────────────────────────────────────────────────────────
LEVERAGE=10
# Hard cap on entry notional (USDT); 0 = off. Use e.g. 50 during first live week (Phase 4).
# MAX_NOTIONAL_USDT=0
# CAPITAL_PER_TRADE_USDT > 0 prefers USDT margin sizing; 0 uses INR path below.
CAPITAL_PER_TRADE_USDT=0
CAPITAL_PER_TRADE=20000
CAPITAL_PER_TRADE_INR=20000
INR_PER_USDT=85
TARGET_PNL_PCT=0.10
STOP_LOSS_PCT=0.05
TP_PRICE_PCT=0.015
SL_PRICE_PCT=0.01
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT

# ─── Strategy (SMC / MTF) ───────────────────────────────────────────────────
USE_SMC=true
USE_SMC_CONFLUENCE=true
SMC_CONFLUENCE_MODE=standard
SMC_CONFLUENCE_MIN_STANDARD=3
SMC_CONFLUENCE_MIN_SNIPER=4
SMC_CONFLUENCE_TARGET_PCT=0.015
# USE_SOL_MTF_STRATEGY: multi-timeframe stack; requires BINANCE_TIMEFRAMES to include 5m,15m,1h,4h,1d (1m optional for chart).
USE_SOL_MTF_STRATEGY=true

TRADES_CSV_PATH=./logs/trades.csv
TRADE_LOG_PATH=./logs/trades.csv
APP_LOG_PATH=./logs/app.ndjson
# NDJSON on stdout/stderr (same schema as file). false = human-readable `msg {"k":v}` lines.
LOG_JSON_CONSOLE=false

# ─── Paper trading ──────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_MAINT_MARGIN=0.005
PAPER_BASE_SLIPPAGE_BPS=2
PAPER_LATENCY_MS=150
PAPER_LEDGER_DIR=./paper
PAPER_FUNDING_POLL_SEC=300
PAPER_EQUITY_SNAPSHOT_SEC=5

# ─── Binance market data (multiplex / dashboard) ─────────────────────────────
# BINANCE_TIMEFRAMES: comma-separated; first interval is execution LTF close when multiplex runs bot.
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d
BINANCE_HISTORY_BARS=500
BINANCE_DEPTH_LEVELS=20
BINANCE_DEPTH_SPEED=100ms
BINANCE_USE_AGGTRADE=true
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true
# BINANCE_USE_FORCE_ORDER: stream @forceOrder (USD-M) for SMC liquidity sweep hints.
BINANCE_USE_FORCE_ORDER=false
# Stream ALL-symbol liquidation events (!forceOrder@arr) for cascade detection. USD-M only.
BINANCE_USE_GLOBAL_FORCE_ORDER=false
BINANCE_WS_RECONNECT_HOURS=23

# ─── Binance USD-M testnet vs mainnet ───────────────────────────────────────
# BINANCE_FUTURES_TESTNET=true  → REST https://testnet.binancefuture.com
#                                  WS  wss://fstream.binancefuture.com
# BINANCE_FUTURES_TESTNET=false → REST https://fapi.binance.com (mainnet)
# Register testnet account and generate keys at: https://testnet.binancefuture.com
# ⚠️  Testnet and mainnet keys are completely separate systems.
#     Using the wrong key for the active endpoint → -2015 Invalid API-key error.
BINANCE_FUTURES_TESTNET=false

# ─── Binance FAPI HMAC — TESTNET keys ────────────────────────────────────────
# Used automatically when BINANCE_FUTURES_TESTNET=true.
# Generate at https://testnet.binancefuture.com → API Management.
# These keys ONLY work against testnet endpoints.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# ─── Binance FAPI HMAC — MAINNET keys ────────────────────────────────────────
# Used automatically when BINANCE_FUTURES_TESTNET=false.
# Create at binance.com → API Management → enable Futures → restrict by IP.
# ⚠️  Never paste mainnet keys here while BINANCE_FUTURES_TESTNET=true.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Live trading safety interlock ───────────────────────────────────────────
# Must be true to place real orders on mainnet (BINANCE_FUTURES_TESTNET=false,
# EXECUTION_MODE=live, BINANCE_EXECUTION_ADAPTER=true).
# Prevents accidental real-money trades during development.
# Keep false until you have verified the full pipeline on testnet.
CONFIRMED_LIVE_TRADING=false
# Optional alias: when CONFIRMED_LIVE_TRADING is unset or empty, `CONFIRMED_LIVE=true`
# is accepted with the same meaning (TODO §20.2 / deployment checklist wording).
# CONFIRMED_LIVE=false

BINANCE_EXECUTION_ADAPTER=false
# Private user-data WS (ORDER_TRADE_UPDATE, ACCOUNT_UPDATE). Auto-on when adapter+live.
BINANCE_PRIVATE_WS_ENABLED=false

# Dead-man auto-cancel: renew `POST /fapi/v1/countdownCancelAll` this often (ms). 0 = disabled.
BINANCE_DEADMAN_COUNTDOWN_MS=0
# Session drawdown guard: halt new entries + cancel open orders when USDT wallet balance falls this
# fraction below the session peak (from ACCOUNT_UPDATE + startup account). 0 = disabled. Example: 0.03 = 3%.
DAILY_DRAWDOWN_KILL_PCT=0
# Pause new entries when `GET /fapi/v1/rateLimit/order` ORDER row count/limit ≥ this (0 = disabled). Example: 0.92
ORDER_RATE_LIMIT_PAUSE_THRESHOLD=0
# Max bid-ask spread in bps to allow entry (0 = disabled). Rejects entries when spread is wide.
MAX_ENTRY_SPREAD_BPS=0
# Max concurrent open positions across all symbols (0 = unlimited).
MAX_OPEN_POSITIONS=0

# ── Event-bus execution path (Phase 1 architecture) ───────────────────────
# Route strategy signals through:
#   actor → strategy.signal → SignalToOrderBridge → RiskEngine → ExecutionBridge → adapter
# Default false: actors observe events but do not place orders; the legacy
# HybridOrchestrator path still owns execution. Flip to true after verifying
# parity in paper/replay. Do NOT enable on a live exchange until cutover is
# fully validated — both paths firing means duplicate orders.
EVENT_BUS_EXECUTION_ENABLED=true
# RiskEngine portfolio caps (event-bus path only).
# MAX_TOTAL_EXPOSURE_USDT: sum of open notional across all symbols.
MAX_TOTAL_EXPOSURE_USDT=100000
# MAX_OPEN_SYMBOLS: distinct symbols with open positions.
MAX_OPEN_SYMBOLS=5
# SignalToOrderBridge: drop signals below this confidence (0-1).
MIN_SIGNAL_CONFIDENCE=0.5
# Cooldown between consecutive event-bus orders per symbol (ms).
EVENT_BUS_ORDER_COOLDOWN_MS=60000

# ── Seykota trend-follower strategy (event-bus path only) ──────────────────
# Modernized Ed Seykota: HTF EMA bias + LTF EMA stack + ADX regime filter +
# ATR position sizing + ATR trailing stop. Disables default SMC/SOL-MTF
# strategy attachment when true — only Seykota runs per symbol.
SEYKOTA_ENABLED=false
SEYKOTA_HTF=1h
SEYKOTA_FAST_EMA=20
SEYKOTA_SLOW_EMA=50
SEYKOTA_ADX_PERIOD=14
# Skip entries when ADX < threshold (chop filter). 20 lenient, 25 strict.
SEYKOTA_ADX_THRESHOLD=20
SEYKOTA_ATR_PERIOD=14
# Initial stop + trailing distance = atrMult * ATR. 3 = Seykota classic, 2 tighter.
SEYKOTA_ATR_MULT=3
# Min ATR/price ratio. Below this market is dead; skip. 0.003 = 0.3%.
SEYKOTA_MIN_ATR_PCT=0.003
# Risk per trade as fraction of equity. 0.005 = 0.5% (Seykota: 0.5–1%).
SEYKOTA_RISK_PCT=0.005
# Account equity for sizing math. Keep in sync with PAPER_INITIAL_BALANCE_USDT.
SEYKOTA_EQUITY_USDT=10000
SEYKOTA_MIN_BARS=80
# Wick protection: set false to trigger SL/trail on bookticker (mid-bar). true = close-of-bar only.
SEYKOTA_KLINE_ONLY=true
# Partial TP: book profit at +1R (1.0 * ATR). 0 to disable.
SEYKOTA_PARTIAL_TP_R=0
# Fraction to close at partial TP (0.5 = 50%).
SEYKOTA_PARTIAL_TP_PCT=0.5
# SMC structure-break exit: close if BOS/CHoCH flips against position.
SEYKOTA_SMC_EXIT_ENABLED=false
# Pyramiding: max additions to winning trade. 0 to disable.
SEYKOTA_PYRAMID_MAX_ADDS=0
# Distance to add pyramid (1.0 = every +1R move).
SEYKOTA_PYRAMID_R_DISTANCE=1.0
# Volatility-adjusted sizing: scale position down when rv > VOL_BASELINE.
VOL_ADJUSTED_SIZING=false
VOL_BASELINE=0
# UTC hours for new entries (e.g. "02:00-21:00"). Empty = no restriction.
TRADING_HOURS_UTC=
# Entry order type: MARKET (default) or LIMIT_GTX (post-only maker fill).
ENTRY_ORDER_TYPE=MARKET
# Trailing stop callback rate (%). 0 = use fixed SL.
TRAILING_STOP_CALLBACK_RATE=0

# ─── Binance WebSocket trading API (Ed25519, optional advanced) ─────────────
# ws-fapi session / order.place — separate from public fstream; not required for REST adapter.
# https://developers.binance.com/docs/derivatives/usds-margined-futures/websocket-api-general-info
BINANCE_FAPI_WS_ENABLED=false
BINANCE_FAPI_API_KEY=
BINANCE_FAPI_ED25519_PRIVATE_KEY_PATH=
BINANCE_FAPI_WS_URL=
BINANCE_FAPI_WS_REQUEST_TIMEOUT_MS=30000
BINANCE_FAPI_WS_HIDE_RATELIMITS=false

# ─── Dashboard WebSocket (same process as `npm run dev` / `npm start`) ───────
# When true, the bot exposes the browser UI bridge on ws://DASHBOARD_BIND:DASHBOARD_PORT
# using the same multiplex-backed store/orderbook/trade tape as the strategy (no duplicate Binance WS).
# Optional UI: `npm run ui:dev` (Vite). `npm run dashboard` is an alias with this flag set.
DASHBOARD_ENABLED=false
DASHBOARD_PORT=4001
DASHBOARD_BIND=127.0.0.1
DASHBOARD_STORE_MAX_BARS=100000
# Vite dashboard UI only: fallback display LTP decimals (0…8) before the bot sends `ltpDecimalPlaces`.
# Chart smooth LTP uses display+1 decimal internally; axis, book, and tape use display only.
# Restart `npm run ui:dev` / rebuild after change.
VITE_LTP_DECIMAL_PLACES=4
# Proportional smoothing for current price line (0.01 = extremely slow/smooth, 1.0 = instant snap).
VITE_CHART_LTP_SMOOTHING=0.1

# ─── Dashboard AI brief (ollama JS) ─────────────────────────────────────────
# AI_MARKET_BRIEF_ENABLED: optional narrative when dashboard is enabled (see DASHBOARD_ENABLED).
# OLLAMA_TARGET: local | cloud (URLs fixed in code: 127.0.0.1:11434 vs https://ollama.com).
# OLLAMA_API_KEY: required when OLLAMA_TARGET=cloud.
# Thinking models (e.g. qwen3.5): use a recent Ollama. Set AI_BRIEF_THINK_ENABLED=true for `think: true`; AI_BRIEF_STREAM_ENABLED=true streams partial briefs over the dashboard WS.
AI_MARKET_BRIEF_ENABLED=true
AI_PROVIDER=ollama  # `ollama` or `openai` (for llama.cpp)
AI_OPENAI_URL=http://127.0.0.1:8080/v1
AI_OPENAI_MODEL=local-model
AI_BRIEF_THINK_ENABLED=true
AI_BRIEF_STREAM_ENABLED=true
OLLAMA_TARGET=local
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_API_KEY=
AI_BRIEF_INTERVAL_SEC=120
AI_BRIEF_THINK_ENABLED=true
# AI_BRIEF_STREAM_ENABLED=true
# Ollama HTTP abort (market brief + SuperTrend tune). Larger context windows (AI_CONTEXT_SIZE) 
# and cold-loading models often need 120_000+ ms. Set to 0 to disable timeout.
AI_REQUEST_TIMEOUT_MS=120000
# AI_CONTEXT_SIZE: total context window (input + output tokens). Defaults to 8192 if unset.
# Increasing this allows more tool data but significantly increases processing time.
AI_CONTEXT_SIZE=8192
# AI_SUPERTREND_TUNING_ENABLED: when true, periodically asks Ollama for SuperTrend atrPeriod (5–30) and multiplier (1.5–5); chart math stays local.
# AI_SUPERTREND_TUNING_INTERVAL_SEC: minimum seconds between tuning calls per symbol (60–3600).
AI_SUPERTREND_TUNING_ENABLED=true
AI_SUPERTREND_TUNING_INTERVAL_SEC=300

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
# Professional AI-trader alerts via Telegram Bot API.
# Create a bot via @BotFather and get chat ID via @userinfobot or similar.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_RATE_PER_MIN=20

# ─── ML / AI inference pipeline ──────────────────────────────────────────────
# ML_ENABLED: when true, builds feature vectors on each heartbeat, records to CSV,
# and optionally calls the Python inference server for ML-gated entries.
ML_ENABLED=false
# Python FastAPI inference server URL (see ml_bot/inference_server.py).
ML_INFERENCE_URL=http://localhost:8000/infer
# Minimum model probability threshold to act on a signal.
ML_MIN_PROBABILITY=0.65
# Minimum edge in bps after fees for ML gate to allow entry.
ML_MIN_EDGE_BPS=8
# Shadow mode: log ML predictions but don't override SMC entry decisions.
ML_SHADOW_MODE=true
# Inference HTTP timeout (ms). Keep low — fallback to rule-based if server is slow.
ML_INFERENCE_TIMEOUT_MS=2000
# Directory for recorded feature vectors (training data collection).
ML_FEATURE_DIR=./data/features
# Directory for prediction outcome logs (calibration).
ML_PREDICTION_DIR=./data/predictions

# ─── Shadow mode (pre-deployment validation) ────────────────────────────────
# SHADOW_MODE: connect to live data, run full signal pipeline, but suppress all order
# placement at the adapter level. Logs what would have been sent. Different from READ_ONLY —
# shadow mode still exercises the complete execution path minus the final API call.
SHADOW_MODE=false
# MAX_NOTIONAL_USDT: per-order notional cap (qty * price). 0 = disabled.
MAX_NOTIONAL_USDT=0

# ─── Prometheus metrics endpoint ──────────────────────────────────────────────
# HTTP server on this port exposing /metrics (Prometheus text format) and /health.
# Set 0 to disable.
PROMETHEUS_PORT=9090

# ─── Process shutdown (orchestrator / lifecycle) ────────────────────────────
SHUTDOWN_TIMEOUT_MS=5000
SHUTDOWN_FORCE_EXIT_MS=10000

# ─── Runtime control plane (HTTP) ────────────────────────────────────────────
# Exposes GET/POST /runtime/config, GET /runtime/status, POST /runtime/kill|unkill.
# Binds to 127.0.0.1 only. Set 0 to disable.
CONTROL_PORT=4002
# Bearer token enforced on EVERY request when set.
# REQUIRED in EXECUTION_MODE=live with CONTROL_PORT>0 — startup throws if missing.
# Must be ≥16 chars. Generate with: openssl rand -hex 32
CONTROL_AUTH_TOKEN=

# ─── Postgres for PnL dashboard + append-only event store ───────────────────
# Drives trades/positions/equity tables AND the events table (Phase 1 event
# sourcing). Required for deterministic replay via scripts/replay.ts.
# docker-compose stack:up exposes Postgres on host port 5434. Apply schema:
#   bash pnl-dashboard/db/migrate.sh
POSTGRES_URL=postgres://postgres:postgres@localhost:5434/bot

# ─── Redis event bus (optional) ──────────────────────────────────────────────
# When set, the bot publishes ticks, signals, and position events to Redis
# pub/sub channels, and writes live position/balance state to Redis keys.
# Leave empty (default) to run without Redis — all publish calls are no-ops.
# Docker: REDIS_URL=redis://redis:6379 is injected by docker-compose.yml.
# Local:  start Redis via `docker run -p 6379:6379 redis:7-alpine` then set:
REDIS_URL=
# Port the standalone WS gateway listens on (ws://host:GATEWAY_PORT).
GATEWAY_PORT=4000

# ─── Self-learning runtime (Ollama proposal loop) ───────────────────────────
# Enables periodic proposal generation + policy validation + config persistence.
SELF_LEARNING_ENABLED=false
# Safety interlock: when true, runtime is blocked unless EXECUTION_MODE=paper.
SELF_LEARNING_PAPER_ONLY=true
# Loop cadence in ms (default 1h).
SELF_LEARNING_INTERVAL_MS=3600000
# Ollama endpoint/model used by self-learning runtime.
SELF_LEARNING_OLLAMA_URL=http://127.0.0.1:11434
SELF_LEARNING_OLLAMA_MODEL=llama3.1:8b-instruct-q8_0

