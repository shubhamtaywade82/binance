# Binance — USD-M futures public market data (derivatives): https://developers.binance.com/docs/derivatives
BINANCE_PRODUCT=usdm
# Leave unset to use mainnet defaults; set both when using futures testnet (demo):
# BINANCE_FUTURES_TESTNET=true
BINANCE_REST_BASE=https://fapi.binance.com
# Root futures WS host (no /market suffix). Code opens …/market/stream and …/public/stream.
BINANCE_WS_BASE=wss://fstream.binance.com
BINANCE_SYMBOL=SOLUSDT
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# CoinDCX (same names as coindcx-bot)
COINDCX_API_KEY=
COINDCX_API_SECRET=
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com

# Mapped CoinDCX futures pair for BINANCE_SYMBOL
COINDCX_PAIR=B-SOL_USDT

# Safety: never place real orders unless both are set
READ_ONLY=true
EXECUTION_ENABLED=false

# Logs: heartbeat every N seconds (mark + biases). 0 = off
LOG_HEARTBEAT_SEC=60

# Warn if no LTP/mark/ticker after WS open (seconds). 0 = off
LTP_CONNECT_WARN_SEC=15

# USD-M: poll GET /fapi/v1/premiumIndex for mark (often works when fstream WS is blocked). 0 = WS only
USDM_MARK_REST_POLL_SEC=5

# Append JSON lines (ts, level, msg, …). Leave empty for stdout only.
# APP_LOG_PATH=./logs/app.ndjson

# Risk / sizing (CAPITAL_PER_TRADE treated as USDT-equivalent margin)
LEVERAGE=10
CAPITAL_PER_TRADE=20000
CAPITAL_PER_TRADE_INR=20000
INR_PER_USDT=85
TARGET_PNL_PCT=0.10
STOP_LOSS_PCT=0.05
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT
USE_SMC=true
TRADES_CSV_PATH=./logs/trades.csv
TRADE_LOG_PATH=./logs/trades.csv

# Execution layer
EXECUTION_MODE=paper            # paper|live (default paper)
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_MAINT_MARGIN=0.005
PAPER_BASE_SLIPPAGE_BPS=2
PAPER_LATENCY_MS=150
PAPER_LEDGER_DIR=./paper
PAPER_FUNDING_POLL_SEC=300
PAPER_EQUITY_SNAPSHOT_SEC=5

# Market data (multiplex feed)
BINANCE_TIMEFRAMES=15m,1h        # comma-separated, first=LTF, second=HTF
BINANCE_HISTORY_BARS=500         # 50..2000
BINANCE_DEPTH_LEVELS=20          # 0|5|10|20 (0 = full diff stream + LocalOrderBook)
BINANCE_DEPTH_SPEED=100ms        # 100ms|500ms
BINANCE_USE_AGGTRADE=true
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true
BINANCE_WS_RECONNECT_HOURS=23
# true = USD-M testnet hosts (demo-fapi + fstream.binancefuture.com) when REST/WS bases are unset
# BINANCE_FUTURES_TESTNET=false

# Binance USD-M WebSocket *trading* API (ws-fapi / order.place) — Ed25519 key required; separate from fstream market data
# BINANCE_FAPI_WS_ENABLED=false
# BINANCE_FAPI_API_KEY=
# BINANCE_FAPI_ED25519_PRIVATE_KEY_PATH=
# BINANCE_FAPI_WS_URL=
# BINANCE_FAPI_WS_REQUEST_TIMEOUT_MS=30000
# BINANCE_FAPI_WS_HIDE_RATELIMITS=false

# Lifecycle / shutdown
SHUTDOWN_TIMEOUT_MS=5000
SHUTDOWN_FORCE_EXIT_MS=10000
