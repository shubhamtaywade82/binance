# =============================================================================
# SOL 1.5% Capture Bot — Environment Configuration
# =============================================================================
# Defaults are baked in. Only override what you need.

# ─── Market ──────────────────────────────────────────────────────────────────
# sol | eth | btc | custom
TRADING_ASSET=sol
# TRADING_ASSET=eth
# TRADING_ASSET=btc
# TRADING_ASSET=custom   → then set BINANCE_SYMBOL + COINDCX_PAIR manually

# ─── Execution Mode ──────────────────────────────────────────────────────────
# paper (default) — simulated fills, no exchange orders sent.
# live  — real orders via Binance FAPI (set BINANCE_EXECUTION_ADAPTER=true)
#         or CoinDCX (legacy).
EXECUTION_MODE=paper
READ_ONLY=true
PLACE_ORDER=true

# ─── Binance FAPI — Live Trading (Mainnet) ───────────────────────────────────
# Required when EXECUTION_MODE=live + BINANCE_EXECUTION_ADAPTER=true.
# Create an API key on binance.com → API Management → enable Futures trading.
# Restrict by IP address for safety before going live.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set true to route live orders through Binance FAPI instead of CoinDCX.
BINANCE_EXECUTION_ADAPTER=false

# Enables private user-data WebSocket (ORDER_TRADE_UPDATE, ACCOUNT_UPDATE).
# Auto-enabled when BINANCE_EXECUTION_ADAPTER=true + EXECUTION_MODE=live.
BINANCE_PRIVATE_WS_ENABLED=false

# ─── Binance FAPI — Testnet ───────────────────────────────────────────────────
# REST:  https://testnet.binancefuture.com
# WS:    wss://fstream.binancefuture.com
# Register at: https://testnet.binancefuture.com
BINANCE_FUTURES_TESTNET=false
# Testnet API keys (separate set from mainnet):
# BINANCE_API_KEY=<testnet_key>
# BINANCE_API_SECRET=<testnet_secret>

# ─── Market Data Streams ─────────────────────────────────────────────────────
# Mainnet WS:  wss://fstream.binance.com  (public + market routes)
# Testnet WS:  wss://fstream.binancefuture.com
# BINANCE_WS_BASE=wss://fstream.binance.com

# Mainnet REST: https://fapi.binance.com
# Testnet REST: https://testnet.binancefuture.com  (set BINANCE_FUTURES_TESTNET=true)
# BINANCE_REST_BASE=https://fapi.binance.com

# Timeframes for SMC multi-timeframe engine (execution TF first).
BINANCE_TIMEFRAMES=5m,15m,1h,4h,1d

# Stream liquidation orders for SMC liquidity sweep detection. USD-M only.
BINANCE_USE_FORCE_ORDER=false

# ─── Strategy ─────────────────────────────────────────────────────────────────
# 1.5% price target, 1% stop loss (matches SMC-CE v5 capture profile).
TP_PRICE_PCT=0.015
SL_PRICE_PCT=0.01
LEVERAGE=10
MIN_CONFIDENCE=0.65
SMC_CONFLUENCE_MODE=standard

# ─── CoinDCX (Legacy Live Execution) ─────────────────────────────────────────
# Required only when EXECUTION_MODE=live + BINANCE_EXECUTION_ADAPTER=false.
COINDCX_API_KEY=
COINDCX_API_SECRET=
# API_BASE_URL=https://api.coindcx.com

# ─── Binance WebSocket Trading API (Ed25519 — optional advanced) ──────────────
# Alternative low-latency order path via ws-fapi.
# Not required when using BINANCE_EXECUTION_ADAPTER (HMAC REST is sufficient).
# BINANCE_FAPI_WS_ENABLED=false
# BINANCE_FAPI_API_KEY=
# BINANCE_FAPI_ED25519_PRIVATE_KEY_PATH=./keys/binance_ed25519.pem

# ─── Logging ──────────────────────────────────────────────────────────────────
APP_LOG_PATH=./logs/app.ndjson
LOG_HEARTBEAT_SEC=60

# ─── Paper Trading ────────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_LEDGER_DIR=./paper
