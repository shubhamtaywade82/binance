    {
      "name": "WebSocket - USD-M Futures Market Streams",
      "description": "USD-M futures WebSocket market streams. Binance routes regular market data under /market and high-frequency public order-book data under /public.",
      "item": [
        {
          "name": "Market Raw - Aggregate Trades",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{usdm_ws_base_url}}/market/ws/{{usdm_stream_symbol}}@aggTrade",
            "description": "Open as a WebSocket request. Stream name: <symbol>@aggTrade. Example default: btcusdt@aggTrade"
          },
          "response": []
        },
        {
          "name": "Market Raw - Mark Price 1s",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{usdm_ws_base_url}}/market/ws/{{usdm_stream_symbol}}@markPrice@1s",
            "description": "Open as a WebSocket request. Stream name: <symbol>@markPrice@1s"
          },
          "response": []
        },
        {
          "name": "Market Combined - Trade Kline Mark Liquidation",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{usdm_ws_base_url}}/market/stream?streams={{usdm_stream_symbol}}@aggTrade/{{usdm_stream_symbol}}@kline_{{interval}}/{{usdm_stream_symbol}}@markPrice@1s/{{usdm_stream_symbol}}@forceOrder",
            "description": "Open as a WebSocket request. Combined market streams return {\"stream\":\"...\",\"data\":{...}}."
          },
          "response": []
        },
        {
          "name": "Public Raw - Partial Depth",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{usdm_ws_base_url}}/public/ws/{{usdm_stream_symbol}}@depth{{depth_levels}}@{{depth_speed}}",
            "description": "Open as a WebSocket request. Valid depth_levels: 5, 10, 20. Valid depth_speed: 100ms, 500ms."
          },
          "response": []
        },
        {
          "name": "Public Combined - Book Ticker and Depth",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{usdm_ws_base_url}}/public/stream?streams={{usdm_stream_symbol}}@bookTicker/{{usdm_stream_symbol}}@depth{{depth_levels}}@{{depth_speed}}",
            "description": "Open as a WebSocket request. Combines bookTicker and partial depth from the /public route."
          },
          "response": []
        },
        {
          "name": "Market Dynamic Subscribe",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{usdm_ws_base_url}}/market/ws",
            "description": "Open as a WebSocket request, then send this JSON message from Postman:\n\n{\n  \"method\": \"SUBSCRIBE\",\n  \"params\": [\n    \"{{usdm_stream_symbol}}@aggTrade\",\n    \"{{usdm_stream_symbol}}@kline_{{interval}}\",\n    \"{{usdm_stream_symbol}}@markPrice@1s\"\n  ],\n  \"id\": 1\n}\n\nUse /public/ws for public order-book streams such as {{usdm_stream_symbol}}@depth{{depth_levels}}@{{depth_speed}} and {{usdm_stream_symbol}}@bookTicker."
          },
          "response": []
        }
      ]
    },
    {
