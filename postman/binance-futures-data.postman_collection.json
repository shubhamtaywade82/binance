            "method": "GET",
            "header": [],
            "url": "{{coinm_ws_base_url}}/stream?streams={{coinm_stream_symbol}}@aggTrade/{{coinm_stream_symbol}}@kline_{{interval}}/{{coinm_stream_symbol}}@markPrice@1s/{{coinm_stream_symbol}}@forceOrder",
            "description": "Open as a WebSocket request. Combined streams return {\"stream\":\"...\",\"data\":{...}}."
          },
          "response": []
        },
        {
          "name": "Raw - Partial Depth",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{coinm_ws_base_url}}/ws/{{coinm_stream_symbol}}@depth{{depth_levels}}@{{depth_speed}}",
            "description": "Open as a WebSocket request. Valid depth_levels: 5, 10, 20. Valid depth_speed: 100ms, 500ms."
          },
          "response": []
