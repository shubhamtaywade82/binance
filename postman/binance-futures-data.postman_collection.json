        {
          "name": "Combined - Book Ticker and Depth",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{coinm_ws_base_url}}/stream?streams={{coinm_stream_symbol}}@bookTicker/{{coinm_stream_symbol}}@depth{{depth_levels}}@{{depth_speed}}",
            "description": "Open as a WebSocket request. Combines bookTicker and partial depth."
          },
          "response": []
        },
        {
          "name": "Dynamic Subscribe",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{coinm_ws_base_url}}/ws",
            "description": "Open as a WebSocket request, then send this JSON message from Postman:\n\n{\n  \"method\": \"SUBSCRIBE\",\n  \"params\": [\n    \"{{coinm_stream_symbol}}@aggTrade\",\n    \"{{coinm_stream_symbol}}@kline_{{interval}}\",\n    \"{{coinm_stream_symbol}}@markPrice@1s\",\n    \"{{coinm_stream_symbol}}@depth{{depth_levels}}@{{depth_speed}}\"\n  ],\n  \"id\": 1\n}"
          },
          "response": []
        }
      ]
    }
