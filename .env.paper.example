# =============================================================================
#  PAPER-MAINNET profile — Binance USD-M Perp public data + simulated execution
# =============================================================================
#  Quick start:
#      1. cp .env.secrets.example .env.secrets  # and set your keys there once
#      2. cp .env.paper.example .env
#      3. npm run dashboard
# =============================================================================

# ─── Market & symbol preset ─────────────────────────────────────────────────
TRADING_ASSET=sol
BINANCE_PRODUCT=usdm
BINANCE_SYMBOL=SOLUSDT
BINANCE_WATCHLIST=SOLUSDT,BTCUSDT,ETHUSDT,SUIUSDT,AVAXUSDT,LINKUSDT,XRPUSDT
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# ─── Execution safety — PAPER-MAINNET ───────────────────────────────────────
EXECUTION_MODE=paper
PLACE_ORDER=true
READ_ONLY=true
SHADOW_MODE=false
CONFIRMED_LIVE_TRADING=false
BINANCE_EXECUTION_ADAPTER=false
BINANCE_PRIVATE_WS_ENABLED=false
EVENT_BUS_EXECUTION_ENABLED=true
LIVE_USE_WS_FOR_FILLS=false

# ─── Risk & sizing ──────────────────────────────────────────────────────────
LEVERAGE=5
MAX_NOTIONAL_USDT=0
CAPITAL_PER_TRADE_USDT=1000
INR_PER_USDT=98
TP_PRICE_PCT=0.015
SL_PRICE_PCT=0.01
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT

# ─── Adaptive regime-aware strategy ─────────────────────────────────────────
ADAPTIVE_STRATEGY_ENABLED=true
ADAPTIVE_EQUITY_USDT=10000
ADAPTIVE_COOLDOWN_MS=300000
SIGNAL_ALLOCATOR_ENABLED=true
SIGNAL_ALLOCATOR_FLUSH_MS=1500
MIN_SIGNAL_CONFIDENCE=0.6
EVENT_BUS_ORDER_COOLDOWN_MS=300000

# ─── Exit managers ─────────────────────────────────────────────────────────
SEYKOTA_TRAIL_INTRABAR=true
PARTIAL_TP_ENABLED=true
PARTIAL_TP_R=1
PARTIAL_TP_FRACTION=0.5
TIME_STOP_ENABLED=true
TIME_STOP_BARS=24
STRUCTURE_EXIT_ENABLED=true
STRUCTURE_SWING_LOOKBACK=5
FUNDING_EXIT_ENABLED=true
FUNDING_EXIT_THRESHOLD_BPS=50

# ─── Paper engine config ───────────────────────────────────────────────────
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_MAINT_MARGIN=0.005
PAPER_BASE_SLIPPAGE_BPS=2
PAPER_LATENCY_MS=150
PAPER_LEDGER_DIR=./paper
PAPER_FUNDING_POLL_SEC=300
PAPER_EQUITY_SNAPSHOT_SEC=5
PAPER_PARTIAL_FILLS=true

# ─── Market Data (Mainnet) ──────────────────────────────────────────────────
BINANCE_FUTURES_TESTNET=false
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d
BINANCE_USE_AGGTRADE=true
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true
BINANCE_USE_FORCE_ORDER=true
BINANCE_WS_RECONNECT_HOURS=23

# ─── Observability & Infrastructure ─────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4001
AI_MARKET_BRIEF_ENABLED=true
OLLAMA_MODEL=qwen3.5:4b
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
POSTGRES_URL=postgres://postgres:postgres@localhost:5434/bot
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=binance
GATEWAY_PORT=4000

# ─── Telegram alerts ────────────────────────────────────────────────────────
# Bot token from @BotFather. Chat ID is your DM with the bot (use @userinfobot).
# Leave blank to disable Telegram alerts entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated category filter. Available: critical,trade,signal,trail,wallet,ai,system
# Empty = default loud set: critical+trade+signal+ai+system.
TELEGRAM_ALERT_LEVELS=critical,trade,signal,ai,system
# Token bucket — max msgs/min sent. Telegram per-chat ceiling is ~30/sec.
TELEGRAM_RATE_PER_MIN=20
# Per-symbol trail.update throttle (sec). 0 = unthrottled (noisy).
TELEGRAM_TRAIL_THROTTLE_SEC=300
# Wallet update fires when equity moves >= this fraction (0.02 = 2%) OR every
# TELEGRAM_WALLET_INTERVAL_MIN, whichever comes first.
TELEGRAM_WALLET_DELTA_PCT=0.02
TELEGRAM_WALLET_INTERVAL_MIN=30
# Periodic digest summarising W/L + net PnL since last digest. 0 = disable.
TELEGRAM_DIGEST_INTERVAL_MIN=360
LOG_JSON_CONSOLE=true
APP_LOG_PATH=./logs/app_paper.ndjson
