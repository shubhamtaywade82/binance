# =============================================================================
#  PAPER-MAINNET profile — Binance USD-M Perp public data + simulated execution
# =============================================================================
#  Quick start:
#      cp .env.paper.example .env
#      npm run dashboard        # bot + dashboard WS on :4001
#      npm run pnl:ui           # PnL dashboard frontend (separate terminal)
#      # or one-shot: npm run stack:up
#
#  What this profile does:
#      · Connects to Binance USD-M Futures MAINNET market data (no testnet)
#      · Runs the FULL strategy / SMC / MTF / ML / AI pipeline (all optional toggles ON below)
#      · Simulates every order through the local paper engine (paper/wallet.json); partial fills ON
#      · MCP-backed dashboard AI when `docker compose up -d mcp-server` + Ollama tool-capable model
#      · Writes equity snapshots + trades to Postgres if POSTGRES_URL is set
#      · NEVER places a live order — CONFIRMED_LIVE_TRADING + BINANCE_EXECUTION_ADAPTER stay off
#
#  See docs/PAPER_TRADING.md for the verification checklist.
# =============================================================================

# ─── Market & symbol preset ─────────────────────────────────────────────────
TRADING_ASSET=sol
BINANCE_PRODUCT=usdm
BINANCE_REST_BASE=
BINANCE_WS_BASE=
BINANCE_SYMBOL=SOLUSDT
# Tier-1 (BTC/ETH/SOL) + Tier-2 (SUI/AVAX/LINK) — see docs/PAPER_TRADING.md
BINANCE_WATCHLIST=SOLUSDT,BTCUSDT,ETHUSDT,SUIUSDT,AVAXUSDT,LINKUSDT,XRPUSDT
BINANCE_KLINE_INTERVAL=15m
BINANCE_HTF_INTERVAL=1h

# ─── CoinDCX (not used in paper mode) ───────────────────────────────────────
COINDCX_API_KEY=
COINDCX_API_SECRET=
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com
COINDCX_PAIR=B-SOL_USDT

# ─── Execution safety — PAPER-MAINNET ───────────────────────────────────────
# READ_ONLY=true keeps any live adapter mutating-call defensive.
# EXECUTION_MODE=paper routes all fills through src/execution/paper/adapter.ts.
# PLACE_ORDER=true so paper positions actually open (set false for signals-only).
# CONFIRMED_LIVE_TRADING and BINANCE_EXECUTION_ADAPTER MUST stay false here.
READ_ONLY=true
PLACE_ORDER=true
EXECUTION_ENABLED=true
EXECUTION_MODE=paper

LOG_HEARTBEAT_SEC=60
LTP_CONNECT_WARN_SEC=15
USDM_MARK_REST_POLL_SEC=5

# ─── Risk & sizing ──────────────────────────────────────────────────────────
LEVERAGE=5
MAX_NOTIONAL_USDT=0
# Prefer USDT margin sizing in paper mode.
CAPITAL_PER_TRADE_USDT=1000
CAPITAL_PER_TRADE=20000
CAPITAL_PER_TRADE_INR=20000
# Fallback rate when INR_RATE_SOURCE=fixed or the live fetch fails on startup.
INR_PER_USDT=98
TARGET_PNL_PCT=0.10
STOP_LOSS_PCT=0.05
TP_PRICE_PCT=0.015
SL_PRICE_PCT=0.01
MIN_CONFIDENCE=0.65
MIN_SMC_SCORE=2
TAKER_FEE=0.0005
MAKER_FEE=0.0002
FUNDING_FEE_EST=0.0001
MARGIN_CURRENCY=USDT

# ─── Live INR/USDT FX rate (new) ────────────────────────────────────────────
# INR_RATE_SOURCE: binance (USDTINR) | coindcx (USDTINR) | fixed (use INR_PER_USDT).
# INR_RATE_REFRESH_SEC: poll interval (min 15s enforced).
INR_RATE_SOURCE=coindcx
INR_RATE_REFRESH_SEC=300

# ─── Strategy (legacy orchestrator path — DISABLED in event-bus mode) ──────
# Paper testing uses the new event-bus path (actor → adaptive strategy →
# RiskEngine → ExecutionBridge → PaperAdapter). Leave legacy SMC + SOL-MTF
# OFF to prevent duplicate orders from HybridOrchestrator's PositionManager.
USE_SMC=false
USE_SMC_CONFLUENCE=false
SMC_CONFLUENCE_MODE=standard
SMC_CONFLUENCE_MIN_STANDARD=3
SMC_CONFLUENCE_MIN_SNIPER=4
SMC_CONFLUENCE_TARGET_PCT=0.015
USE_SOL_MTF_STRATEGY=false

TRADES_CSV_PATH=./logs/trades.csv
TRADE_LOG_PATH=./logs/trades.csv
APP_LOG_PATH=./logs/app.ndjson
LOG_JSON_CONSOLE=true

# ─── Paper engine ───────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE_USDT=10000
PAPER_MAINT_MARGIN=0.005
PAPER_BASE_SLIPPAGE_BPS=2
PAPER_LATENCY_MS=150
PAPER_LEDGER_DIR=./paper
PAPER_FUNDING_POLL_SEC=300
PAPER_EQUITY_SNAPSHOT_SEC=5
PAPER_PARTIAL_FILLS=true

# ─── Binance market data (multiplex / dashboard) ─────────────────────────────
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d
BINANCE_HISTORY_BARS=2000
BINANCE_DEPTH_LEVELS=20
BINANCE_DEPTH_SPEED=100ms
BINANCE_USE_AGGTRADE=true
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true
BINANCE_USE_FORCE_ORDER=true
BINANCE_USE_GLOBAL_FORCE_ORDER=true
BINANCE_WS_RECONNECT_HOURS=23

# ─── Mainnet, no testnet ────────────────────────────────────────────────────
BINANCE_FUTURES_TESTNET=false

# Testnet keys (unused while BINANCE_FUTURES_TESTNET=false). Leave empty.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Mainnet keys (unused in paper mode — execution adapter stays off). Keep blank.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Hard interlocks: do NOT flip these in this profile.
CONFIRMED_LIVE_TRADING=false
BINANCE_EXECUTION_ADAPTER=false
BINANCE_PRIVATE_WS_ENABLED=false

BINANCE_DEADMAN_COUNTDOWN_MS=0
DAILY_DRAWDOWN_KILL_PCT=0
ORDER_RATE_LIMIT_PAUSE_THRESHOLD=0
MAX_ENTRY_SPREAD_BPS=0
MAX_OPEN_POSITIONS=6

# ── Event-bus execution path (Phase 1 architecture) ───────────────────────
# Paper-trading is the safe place to enable this. When true, signals flow:
#   actor → strategy.signal → SignalToOrderBridge → RiskEngine → ExecutionBridge → PaperAdapter
# Recorded to the append-only events table → deterministic replay via:
#   npx ts-node scripts/replay.ts --from=ISO --to=ISO --symbol=SYMBOL --speed=max
EVENT_BUS_EXECUTION_ENABLED=true
# RiskEngine portfolio caps (event-bus path only).
MAX_TOTAL_EXPOSURE_USDT=50000
MAX_OPEN_SYMBOLS=5
# Drop strategy signals below this confidence (0-1).
MIN_SIGNAL_CONFIDENCE=0.6
# Cooldown between consecutive event-bus orders per symbol (ms).
EVENT_BUS_ORDER_COOLDOWN_MS=300000

# ─── Signal allocator (best-of-bar across watchlist) ───────────────────────
# Buffer simultaneous candidates per 5m close, score by ADX × ATR strength,
# allocate top N to MAX_OPEN_SYMBOLS. Replaces FCFS behaviour.
SIGNAL_ALLOCATOR_ENABLED=true
SIGNAL_ALLOCATOR_FLUSH_MS=1500

# ─── Correlation guard ─────────────────────────────────────────────────────
# Same-direction opens on pairs > threshold are blocked. Stops doubled
# beta exposure (e.g. simultaneous BTC + ETH long).
CORRELATION_THRESHOLD=0.7
CORRELATION_PAIRS_JSON=[{"symbolA":"BTCUSDT","symbolB":"ETHUSDT","correlation":0.85},{"symbolA":"BTCUSDT","symbolB":"SOLUSDT","correlation":0.75},{"symbolA":"ETHUSDT","symbolB":"SOLUSDT","correlation":0.78},{"symbolA":"SOLUSDT","symbolB":"AVAXUSDT","correlation":0.72},{"symbolA":"AVAXUSDT","symbolB":"SUIUSDT","correlation":0.7},{"symbolA":"LINKUSDT","symbolB":"ETHUSDT","correlation":0.65}]

# ─── Adaptive regime-aware strategy (RECOMMENDED for testing) ──────────────
# Classifier picks TREND / BREAKOUT / RANGE / MEAN_REVERT / CHOP per bar
# per symbol and routes to a TradeModeProfile (sizing + TP ladder).
#   TREND       SWING          5/10/15% ladder + trail residual
#   BREAKOUT    BREAKOUT_SCALP 1/2/4% ladder + trail residual
#   RANGE       RANGE_FADE     0.8/1.5% ladder, no trail
#   MEAN_REVERT MEAN_REVERT    0.5/1.0% ladder, fast exit
#   CHOP        — skip
# Mutually exclusive with SEYKOTA_ENABLED (set that to false below).
ADAPTIVE_STRATEGY_ENABLED=true
ADAPTIVE_EQUITY_USDT=10000
ADAPTIVE_COOLDOWN_MS=300000
ADAPTIVE_MODE_OVERRIDES_JSON=

# ─── Exit managers (event-bus path) ────────────────────────────────────────
# Trail reacts on every bookticker tick (wick protection).
SEYKOTA_TRAIL_INTRABAR=true
# Partial close at +N×ATR-stop distance.
PARTIAL_TP_ENABLED=true
PARTIAL_TP_R=1
PARTIAL_TP_FRACTION=0.5
# Time stop: close if open ≥ N execution-TF bars AND adverse.
TIME_STOP_ENABLED=true
TIME_STOP_BARS=24
# Structure exit: close when close breaks recent swing low (LONG) / high (SHORT).
STRUCTURE_EXIT_ENABLED=true
STRUCTURE_SWING_LOOKBACK=5
# Funding-aware exit: close adverse position PreTickWindowSec before funding tick.
FUNDING_EXIT_ENABLED=true
FUNDING_EXIT_THRESHOLD_BPS=50

# ── Seykota trend-follower (legacy single-regime — disabled by default) ────
# Set true only if you want to swap from adaptive multi-regime back to a
# Seykota-only swing trader. Adaptive is recommended for production paper.
# ADAPTIVE_STRATEGY_ENABLED takes precedence when both are true.
SEYKOTA_ENABLED=false
SEYKOTA_HTF=1h
SEYKOTA_FAST_EMA=20
SEYKOTA_SLOW_EMA=50
SEYKOTA_ADX_PERIOD=14
SEYKOTA_ADX_THRESHOLD=20
SEYKOTA_ATR_PERIOD=14
SEYKOTA_ATR_MULT=3
SEYKOTA_MIN_ATR_PCT=0.003
SEYKOTA_RISK_PCT=0.005
SEYKOTA_EQUITY_USDT=10000
SEYKOTA_MIN_BARS=80
# Wick protection: set false to trigger SL/trail on bookticker (mid-bar). true = close-of-bar only.
SEYKOTA_KLINE_ONLY=true
# Partial TP: book profit at +1R (1.0 * ATR). 0 to disable.
SEYKOTA_PARTIAL_TP_R=0
# Fraction to close at partial TP (0.5 = 50%).
SEYKOTA_PARTIAL_TP_PCT=0.5
# SMC structure-break exit: close if BOS/CHoCH flips against position.
SEYKOTA_SMC_EXIT_ENABLED=false
# Pyramiding: max additions to winning trade. 0 to disable.
SEYKOTA_PYRAMID_MAX_ADDS=0
# Distance to add pyramid (1.0 = every +1R move).
SEYKOTA_PYRAMID_R_DISTANCE=1.0
# Multi-asset paper trading: evaluate every symbol in ASSET_TIERS that is also in
# BINANCE_WATCHLIST. Set to false to fall back to single-symbol on BINANCE_SYMBOL.
ENABLE_MULTI_ASSET=true
# JSON map of per-symbol tier overrides applied on top of src/config/asset-tiers.ts.
# Leave empty for defaults. Example: {"SOLUSDT":{"leverage":3,"marginUsdt":1000}}
ASSET_TIER_OVERRIDES_JSON=
VOL_ADJUSTED_SIZING=true
VOL_BASELINE=0.85
TRADING_HOURS_UTC=
ENTRY_ORDER_TYPE=MARKET
TRAILING_STOP_CALLBACK_RATE=0

# ─── Binance ws-fapi (advanced, off for paper) ───────────────────────────────
BINANCE_FAPI_WS_ENABLED=false
BINANCE_FAPI_API_KEY=
BINANCE_FAPI_ED25519_PRIVATE_KEY_PATH=
BINANCE_FAPI_WS_URL=
BINANCE_FAPI_WS_REQUEST_TIMEOUT_MS=30000
BINANCE_FAPI_WS_HIDE_RATELIMITS=false

# ─── Dashboard WebSocket ────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4001
DASHBOARD_BIND=127.0.0.1
DASHBOARD_STORE_MAX_BARS=5000
VITE_LTP_DECIMAL_PLACES=4
VITE_CHART_LTP_SMOOTHING=0.1

# ─── AI market brief (Ollama) ───────────────────────────────────────────────
AI_MARKET_BRIEF_ENABLED=true
AI_BRIEF_THINK_ENABLED=true
AI_BRIEF_STREAM_ENABLED=true
OLLAMA_TARGET=local
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_API_KEY=
AI_BRIEF_INTERVAL_SEC=120
AI_REQUEST_TIMEOUT_MS=60000
# Binance + CoinDCX MCP (streamable-http). Start stack: `docker compose up -d mcp-server`
# then point the bot at the published port (default 4003).
AI_MCP_ENABLED=true
AI_MCP_URL=http://localhost:4003
AI_MCP_MAX_TOOL_ITER=8
AI_SUPERTREND_TUNING_ENABLED=true
AI_SUPERTREND_TUNING_INTERVAL_SEC=300

# ─── ML inference (off by default — event-bus path bypasses ML gate) ───────
# Adaptive + Seykota event-bus strategies don't consult the ML gate.
# Leave off unless you also run ml_bot/inference_server. Setting true with
# no server just logs ECONNREFUSED noise; bot still trades.
ML_ENABLED=false
ML_INFERENCE_URL=http://localhost:8000/infer
ML_MIN_PROBABILITY=0.65
ML_MIN_EDGE_BPS=8
ML_SHADOW_MODE=true
ML_INFERENCE_TIMEOUT_MS=2000
ML_FEATURE_DIR=./data/features
ML_PREDICTION_DIR=./data/predictions

# ─── Shadow mode global ─────────────────────────────────────────────────────
# Keep false: paper adapter already simulates fills; global shadow would suppress orders if wired.
SHADOW_MODE=false

# ─── Prometheus / Control plane ─────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true
CONTROL_PORT=4002

# ─── Postgres for PnL dashboard + append-only event store ──────────────────
# Default for docker-compose stack:up. Edit if you run Postgres elsewhere.
# Also drives the events table (Phase 1 event sourcing) — required for
# deterministic replay via scripts/replay.ts. Apply migrations:
#   bash pnl-dashboard/db/migrate.sh
POSTGRES_URL=postgres://postgres:postgres@localhost:5434/bot

SHUTDOWN_TIMEOUT_MS=5000
SHUTDOWN_FORCE_EXIT_MS=10000

# ─── Redis hot cache (binance:paper:* namespace) ────────────────────────────
# Mirrors wallet + positions + equity stream into Redis so the dashboard
# can subscribe to push updates and the JSONL equity log stays bounded.
# docker-compose stack:up brings up a redis container on :6380 — point
# REDIS_URL at it, or at a host redis on :6379, whichever you prefer.
REDIS_URL=redis://localhost:6379
PAPER_STATE_REDIS=true
# JSONL writes only every Nth onMark snapshot (12 ≈ once per minute).
# 0 disables JSONL entirely; Redis stream remains the high-frequency record.
PAPER_EQUITY_JSONL_EVERY_N=12
REDIS_NAMESPACE=binance
GATEWAY_PORT=4000

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
# Professional AI-trader alerts via Telegram Bot API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
