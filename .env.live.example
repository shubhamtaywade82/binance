# =============================================================================
# LIVE TRADING template — Binance market data + CoinDCX execution
# =============================================================================
# Quick start: cp .env.live.example .env
#
# This file is pre-configured for LIVE execution on CoinDCX while using
# real-time market data from Binance Mainnet.
#
# REQUIREMENTS:
#   1. Add your COINDCX_API_KEY and COINDCX_API_SECRET below.
#   2. Ensure COINDCX_PAIR matches your target asset (preset by TRADING_ASSET).
#   3. BINANCE_API_KEY/SECRET are NOT required (only used for Binance execution).
# =============================================================================

# ─── Market & symbol preset ────────────────────────────────────────────────
TRADING_ASSET=sol
BINANCE_PRODUCT=usdm
BINANCE_SYMBOL=SOLUSDT
# Primary execution pair on CoinDCX. preset by TRADING_ASSET.
COINDCX_PAIR=B-SOL_USDT

# ─── CoinDCX Live Execution Credentials ────────────────────────────────────
# Get these from CoinDCX -> Profile -> API Management
COINDCX_API_KEY=your_coindcx_api_key_here
COINDCX_API_SECRET=your_coindcx_api_secret_here
API_BASE_URL=https://api.coindcx.com
PUBLIC_BASE_URL=https://public.coindcx.com

# ─── Execution & Safety ────────────────────────────────────────────────────
EXECUTION_MODE=live
# Set false to route orders to CoinDCX (default). Set true for Binance execution.
BINANCE_EXECUTION_ADAPTER=false
# Must be false for real execution.
READ_ONLY=false
# Must be true for real execution.
PLACE_ORDER=true
# Safety interlock: must be true to enable mainnet orders.
CONFIRMED_LIVE_TRADING=true

# RECOMMENDED: Set SHADOW_MODE=true for the first 24h to verify signals 
# and logging without placing real exchange orders.
SHADOW_MODE=false

# ─── Risk & Sizing ──────────────────────────────────────────────────────────
LEVERAGE=5
# Hard cap on entry notional (USDT); use 50-100 during first live week.
MAX_NOTIONAL_USDT=50
# USDT amount to risk per trade.
CAPITAL_PER_TRADE_USDT=10
INR_PER_USDT=85
MARGIN_CURRENCY=USDT

# ─── Strategy ───────────────────────────────────────────────────────────────
USE_SMC=true
USE_SMC_CONFLUENCE=true
USE_SOL_MTF_STRATEGY=true

# ── Seykota trend-follower strategy ────────────────────────────────────────
SEYKOTA_ENABLED=false
SEYKOTA_HTF=1h
SEYKOTA_FAST_EMA=20
SEYKOTA_SLOW_EMA=50
SEYKOTA_ADX_PERIOD=14
SEYKOTA_ADX_THRESHOLD=20
SEYKOTA_ATR_PERIOD=14
SEYKOTA_ATR_MULT=3
SEYKOTA_MIN_ATR_PCT=0.003
# Risk per trade as fraction of account equity (0.005 = 0.5%).
SEYKOTA_RISK_PCT=0.005
# Account equity for sizing math. Match with your actual account size.
SEYKOTA_EQUITY_USDT=1000
SEYKOTA_MIN_BARS=80
# Wick protection: set false to trigger SL/trail on bookticker (mid-bar).
SEYKOTA_KLINE_ONLY=true
# Partial TP: book profit at +1R (1.0 * ATR). 0 to disable.
SEYKOTA_PARTIAL_TP_R=0
# SMC structure-break exit: close if BOS/CHoCH flips against position.
SEYKOTA_SMC_EXIT_ENABLED=false
# Pyramiding: max additions to winning trade. 0 to disable.
SEYKOTA_PYRAMID_MAX_ADDS=0

# ─── Logging & Persistence ──────────────────────────────────────────────────
TRADES_CSV_PATH=./logs/trades_live.csv
APP_LOG_PATH=./logs/app_live.ndjson
POSTGRES_URL=postgres://postgres:postgres@localhost:5434/bot

# ─── Binance Market Data (Mainnet) ──────────────────────────────────────────
BINANCE_FUTURES_TESTNET=false
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d
BINANCE_USE_BOOKTICKER=true
BINANCE_USE_MARK_PRICE=true

# ─── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4001
AI_MARKET_BRIEF_ENABLED=true
OLLAMA_MODEL=qwen3.5:4b
