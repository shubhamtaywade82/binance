# =============================================================================
# LIVE-SHADOW template — Live market data + blocked execution (dry run)
# =============================================================================
# Quick start: cp .env.live-shadow.example .env
#
# This file is pre-configured for LIVE market analysis while BLOCKING all
# exchange orders. The bot will LOG every order it WOULD have placed.
#
# WHAT THIS MODE DOES:
#   1. Connects to Binance USD-M Futures MAINNET for real-time prices.
#   2. Runs the full signal and strategy pipeline (SMC, MTF, Seykota).
#   3. Performs all risk management and position sizing calculations.
#   4. BLOCKS the final API call to CoinDCX/Binance.
#   5. LOGS "shadow_would_place_order" events to the console/file.
# =============================================================================

# ─── Market & symbol preset ────────────────────────────────────────────────
TRADING_ASSET=sol
BINANCE_PRODUCT=usdm
BINANCE_SYMBOL=SOLUSDT
BINANCE_WATCHLIST=SOLUSDT,BTCUSDT,ETHUSDT,SUIUSDT,AVAXUSDT,LINKUSDT,XRPUSDT

# ─── Execution & Safety — SHADOW MODE ──────────────────────────────────────
EXECUTION_MODE=live
BINANCE_EXECUTION_ADAPTER=false
# Must be false for the boot-guard (we handle blocking in SHADOW_MODE).
READ_ONLY=false
# Keep true so the bot attempts to process signals into orders.
PLACE_ORDER=true
# Must be true for mainnet connectivity.
CONFIRMED_LIVE_TRADING=true
# THE MASTER GATE: set true to block execution and just log intent.
SHADOW_MODE=true

# ─── Risk & Sizing ──────────────────────────────────────────────────────────
LEVERAGE=5
# Sizing will be calculated using these values even in shadow mode.
CAPITAL_PER_TRADE_USDT=10
INR_PER_USDT=85

# ─── Strategy ───────────────────────────────────────────────────────────────
USE_SMC=true
USE_SMC_CONFLUENCE=true
USE_SOL_MTF_STRATEGY=true

# ─── Logging ────────────────────────────────────────────────────────────────
# Logs will be saved separately to avoid mixing with real trade logs later.
TRADES_CSV_PATH=./logs/trades_shadow.csv
APP_LOG_PATH=./logs/app_shadow.ndjson
POSTGRES_URL=postgres://postgres:postgres@localhost:5434/bot

# ─── Binance Market Data (Mainnet) ──────────────────────────────────────────
BINANCE_FUTURES_TESTNET=false
BINANCE_TIMEFRAMES=5m,15m,1m,1h,4h,1d

# ─── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
AI_MARKET_BRIEF_ENABLED=true
OLLAMA_MODEL=qwen3.5:4b

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
# Professional AI-trader alerts via Telegram Bot API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
