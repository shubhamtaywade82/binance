# ───── Binance adapter (public APIs, no creds required) ─────
BINANCE_PRODUCT=usdm

# ───── DhanHQ adapter ─────
# Option A (preferred): rotated tokens from algo_scalper_api running locally.
# The endpoint should return JSON: { "client_id": "...", "access_token": "...", "expires_at": <unix-sec-or-ms> }
# Use host.docker.internal from inside containers, or http://127.0.0.1:PORT from the host.
ALGO_SCALPER_URL=
ALGO_SCALPER_API_KEY=

# Option B (fallback): static DHAN creds if ALGO_SCALPER_URL is unset.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

DHAN_FEED_MODE=full

# ───── Gateway ─────
GATEWAY_CORS_ORIGIN=*
