{
  "name": "@coindcx/binance-hybrid",
  "version": "0.1.0",
  "private": true,
  "description": "Binance public market data + CoinDCX futures execution",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev:once": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test",
    "ws:ltp": "ts-node scripts/ws-ltp-solusdt.ts",
    "ws:ltp:spot": "USE_SPOT=1 ts-node scripts/ws-ltp-solusdt.ts",
    "futures:ltp": "ts-node scripts/futures-ltp-ws.ts",
    "futures:ltp:rest": "ts-node scripts/futures-ltp-rest.ts",
    "fapi:ws:status": "ts-node scripts/binance-fapi-ws-status.ts",
    "dashboard": "DASHBOARD_ENABLED=true ts-node src/index.ts",
    "dashboard:ui": "concurrently -n bot,vite -c blue,green \"DASHBOARD_ENABLED=true nodemon --watch src --watch config --ext ts,json --exec ts-node src/index.ts\" \"vite\"",
    "ui:dev": "vite",
    "readiness:binance": "ts-node scripts/binance-live-readiness.ts",
    "gateway": "ts-node gateway/ws-server.ts",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dompurify": "^3.4.2",
    "dotenv": "^16.4.7",
    "ioredis": "^5.10.1",
    "lightweight-charts": "^4.1.3",
    "marked": "^18.0.3",
    "ollama": "^0.5.18",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.17.14",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "nock": "^14.0.0",
    "nodemon": "^3.1.9",
    "ts-morph": "^24.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^5.4.11",
    "vitest": "^1.6.0"
  }
}
