{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@coindcx/contracts": ["./packages/contracts/src/index.ts"],
      "@coindcx/indicator-runtime": ["./packages/indicator-runtime/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "packages/contracts/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
